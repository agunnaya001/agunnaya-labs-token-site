# ================================================================
# Phase 1+2 Integration Environment Variables
# Copy this to .env.local and fill in your values
# ================================================================

# PHASE 1: WALLET CONNECTIVITY
# ================================================================

# Base mainnet RPC endpoint (required for reading blockchain data)
# Options:
#   - https://mainnet.base.org (free, public)
#   - https://base.llamarpc.com (free, LlamaRPC)
#   - Get your own from Alchemy, Infura, or QuickNode (paid but faster)
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# AGL Token contract address on Base (do NOT change)
NEXT_PUBLIC_AGL_TOKEN_ADDRESS=0xEA1221B4d80A89BD8C75248Fae7c176BD1854698

# Minimum AGL balance required for gas sponsorship eligibility
# This is in whole tokens (will be multiplied by 10^18 internally)
# Example: 100 = users need 100+ AGL to be eligible for gas-free transactions
NEXT_PUBLIC_AGL_MIN_FOR_SPONSORSHIP=100

# Base mainnet chain ID (do NOT change)
NEXT_PUBLIC_CHAIN_ID=8453

# PHASE 2: GAS SPONSORSHIP WITH PIMLICO
# ================================================================

# Your Pimlico API key (get from https://dashboard.pimlico.io)
# 1. Go to https://dashboard.pimlico.io
# 2. Sign up (free)
# 3. Create a new project
# 4. Select "Base" as the chain
# 5. Copy your API key
# This is PUBLIC (OK to expose to frontend, but rate-limited)
NEXT_PUBLIC_PIMLICO_API_KEY=your_pimlico_api_key_here

# Pimlico webhook signing secret (SECRET - backend only)
# DO NOT use NEXT_PUBLIC_ prefix on this!
# Get from https://dashboard.pimlico.io → Webhooks section
# 1. Create a webhook endpoint: https://yourdomain.com/api/webhooks/pimlico-sponsor
# 2. Copy the signing secret provided
# This is SECRET and should NEVER be exposed to the frontend
PIMLICO_WEBHOOK_SECRET=your_webhook_secret_here

# ================================================================
# IMPORTANT REMINDERS
# ================================================================
# 1. Copy this file to .env.local (which is in .gitignore)
# 2. Fill in the values with your actual keys
# 3. NEVER commit .env.local to git
# 4. For Vercel deployment, add these same variables to project settings
# 5. For NEXT_PUBLIC_* vars in Vercel, enable "Expose to Frontend"
# 6. For PIMLICO_WEBHOOK_SECRET in Vercel, leave "Expose to Frontend" unchecked
# ================================================================
